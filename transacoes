<script>
function trocarBanner(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('bannerPrincipal').style.backgroundImage = `url('${e.target.result}')`;
        }
        reader.readAsDataURL(input.files[0]);
    }
}


function trocarCorHeader() {
    const header = document.getElementById('bannerPrincipal');
    const cores = ['#212529', '#1a1f2e', '#2c1a3d', '#112233'];
    header.style.backgroundColor = cores[Math.floor(Math.random()*cores.length)];
}


function abrirLoginFake() {
    const modal = new bootstrap.Modal(document.getElementById('modalLoginFake'));
    modal.show();
}

function acessoLiberado() {
    alert("Acesso liberado mesmo com erro kkk");
    bootstrap.Modal.getInstance(document.getElementById('modalLoginFake')).hide();
}


